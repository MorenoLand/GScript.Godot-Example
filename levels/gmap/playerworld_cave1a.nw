// Small Interactive NPC

function onCreated() {
  this.x += 0.5;
  showCharacter();
  this.head = "head40.png";
  this.colors[0] = "blue";
  this.colors[1] = "black";
  this.colors[2] = "black";
  this.colors[3] = "black";
  this.colors[4] = "black";
  this.shield = "shield1.gif";
  this.dir = 2;
  setCharAni("sit", null);
}

function onPlayerTouchsMe() {
  if (this.chat.length() > 0) return;
  this.chat = "Hello adventurer!";
  this.scheduleevent(2, "UnsetChat", "");
}

function onUnsetChat() {
  this.chat = "";
}
