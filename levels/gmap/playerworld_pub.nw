// Created by *WanderingWitch (Graal6259711)
function onCreated() {
 this.x += 1;
 this.signWidth = 25; // Max Text Length
 onMarquee( "Players Online:" SPC allplayers.size() );
}

function onMarquee(Message) {
 for( temp.i = 0; temp.i < Message.length() + this.signWidth + 1; temp.i++ ) {
  showText( 25, this.x, this.y + 0.5, "Arial", "", Message.substring( temp.o + temp.i, temp.i ).trim());
  //changeImgZoom(25, 0.75);
  temp.o = (0 - this.signWidth);
  sleep(0.1);
 }
 scheduleEvent( 1, "Marquee", "Players Online:" SPC allplayers.size() );
}
NPCEND
